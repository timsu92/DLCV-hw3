{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git add *|rtk git add *|git -C * add *|rtk git -C * add *)",
        "hooks": [
          {
            "type": "command",
            "command": "uv run ruff check --fix"
          },
          {
            "type": "command",
            "command": "uv run ruff format"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(rtk ls *)",
      "Bash(rtk read *)",
      "Bash(uv run *)",
      "Bash(uv --version)",
      "Bash(rtk tree *)",
      "Bash(rtk pytest *)",
      "Bash(rtk grep *)",
      "Bash(uv add *)",
      "Bash(git add *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git status)",
      "Bash(git commit *)",
      "Bash(git -C * add *)",
      "Bash(git -C * log *)",
      "Bash(git -C * diff *)",
      "Bash(git -C * status)",
      "Bash(git -C * commit *)",
      "Bash(rtk git add *)",
      "Bash(rtk git log *)",
      "Bash(rtk git diff *)",
      "Bash(rtk git status)",
      "Bash(rtk git commit *)",
      "Bash(rtk git -C * add *)",
      "Bash(rtk git -C * log *)",
      "Bash(rtk git -C * diff *)",
      "Bash(rtk git -C * status)",
      "Bash(rtk git -C * commit *)",
      "Bash(python *)",
      "Bash(python3 *)"
    ]
  }
}
