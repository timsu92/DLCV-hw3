{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git add *|rtk git add *|git -C * add *|rtk git -C * add *)",
        "hooks": [
          {
            "type": "command",
            "command": "uv run ruff check --fix"
          },
          {
            "type": "command",
            "command": "uv run ruff format"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(rtk ls *)",
      "Bash(rtk read *)",
      "Bash(uv run *)",
      "Bash(uv add *)"
    ]
  }
}